---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thank You — Syed Gibran"
  description="Your message was received."
  canonical="https://syedgibran.com/thankyou/"
>

  <main id="main-content">

    <section class="thankyou">
      <div class="container">

        <p class="label">received</p>

        <h1 class="thankyou__title">
          I got it.<br />Thank you for reaching out.
        </h1>

        <div class="thankyou__body">
          <p>
            It means something that you did. I will read it
            and I will write back.
          </p>
          <p>
            While you wait, there is always more to read.
          </p>
        </div>

        <a href="/blog/" class="covenant__cta" style="margin-top: var(--space-lg); display: inline-flex;">
          <span>go back to the writing</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor" stroke-width="1"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

      </div>
    </section>

  </main>

</Layout>