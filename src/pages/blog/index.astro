---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title="Writing — Syed Gibran"
  description="Every fracture documented. Every week a bone being set in public. The rebuild, written honestly as it happens."
  canonical="https://syedgibran.com/blog/"
>

  <main id="main-content">

    <section class="blog-header">
      <div class="container">
        <p class="label">the fractures</p>
        <h1 class="blog-header__title">
          Every week, a bone<br />being set in public.
        </h1>
        <p class="blog-header__body">
          No frameworks borrowed. No advice recycled. Just what
          happens when you test marketing on yourself, honestly,
          and write down what you find.
        </p>
      </div>
    </section>

    <div class="container">
      <svg class="crack" viewBox="0 0 720 20" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 10 L120 10 L145 4 L170 14 L192 7 L220 11 L258 5 L290 12 L320 8 L360 10 L720 10"
          fill="none" stroke="currentColor" stroke-width="0.75"
          stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <section class="blog-list">
      <div class="container">
        <div class="blog-list__grid">
          {posts.map((post, index) => (
            <a href={`/blog/${post.id}/`} class="blog-card">
              <div class="blog-card__inner">
                <span class="blog-card__number">
                  {String(posts.length - index).padStart(2, '0')}
                </span>
                <div class="blog-card__content">
                  <span class="blog-card__date">{formatDate(post.data.date)}</span>
                  <h2 class="blog-card__title">{post.data.title}</h2>
                  <p class="blog-card__excerpt">{post.data.description}</p>
                </div>
                <span class="blog-card__arrow">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4"
                      stroke="currentColor" stroke-width="1"
                      stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

</Layout>